## Master Data Analysis: Relations of Player, Team, and MVP Statistics
import pandas as pd

NFL_Defense_Stats = pd.read_csv('./data/02-processed/NFL_Opposition_and_Defensive_Stats.csv') # Columns to join on: Tm (ex: New York Jets), Year (ex: 2000)
Player_Season_and_Career_Stats = pd.read_csv('./data/02-processed/Player_Season_and_Career_Stats.csv') # Columns to join on: Team (ex: NYJ), Season (ex: 2000)
QB_MVP_Votes = pd.read_csv('./data/02-processed/qb_mvp_votes.csv') # Columns to join on: Tm (ex: New York Jets), year (ex: 2000)
Season_Standings = pd.read_csv('./data/02-processed/season_standings.csv') # Columns to join on: Tm (ex: New York Jets), Year (ex: 2000)

# Convert abbreviations from Player_Season_and_Career_Stats to team names for joining
nfl_team_map = {
    # Standard team names
    "ARI": "Arizona Cardinals", "ATL": "Atlanta Falcons", "BAL": "Baltimore Ravens", "BUF": "Buffalo Bills", "CAR": "Carolina Panthers", "CHI": "Chicago Bears", "CIN": "Cincinnati Bengals",
    "CLE": "Cleveland Browns", "DAL": "Dallas Cowboys", "DEN": "Denver Broncos", "DET": "Detroit Lions", "GNB": "Green Bay Packers", "HOU": "Houston Texans", "IND": "Indianapolis Colts",
    "JAX": "Jacksonville Jaguars", "KAN": "Kansas City Chiefs", "LAC": "Los Angeles Chargers", "LAR": "Los Angeles Rams", "LVR": "Las Vegas Raiders", "MIA": "Miami Dolphins",
    "MIN": "Minnesota Vikings", "NOR": "New Orleans Saints", "NWE": "New England Patriots", "NYG": "New York Giants", "NYJ": "New York Jets", "PHI": "Philadelphia Eagles",
    "PIT": "Pittsburgh Steelers", "SEA": "Seattle Seahawks", "SFO": "San Francisco 49ers", "TAM": "Tampa Bay Buccaneers", "TEN": "Tennessee Titans", "WAS": "Washington Commanders",

    # Historical abbreviations (Teams that changed names due to changing cities)
    "OAK": "Oakland Raiders", "SDG": "San Diego Chargers", "STL": "St. Louis Rams",

    # Combined team abbreviations (SOME QUARTERBACKS HAVE MULTIPLE TEAMS DUE TO TRADES. WE PAY ATTENTION TO THE TEAM WHO RECEIVED THE PLAYER)
    "CINCLE": "Cleveland Browns", "MIANYG": "New York Giants", "NWEBAL": "Baltimore Ravens", "ARIMIN": "Minnesota Vikings", "CARLAR": "Los Angeles Rams",
    "NYJBAL": "Baltimore Ravens", "NWESFO": "San Francisco 49ers", "BUFDAL": "Dallas Cowboys", "CHIBAL": "Baltimore Ravens", "HOUSEA": "Seattle Seahawks",
    "HOUBAL": "Baltimore Ravens", "DALHOU": "Houston Texans", "CARCLE": "Cleveland Browns", "GNBOAK": "Oakland Raiders", "MINTAM": "Tampa Bay Buccaneers",
    "DENKAN": "Kansas City Chiefs", "BUFJAX": "Jacksonville Jaguars", "KANMIA": "Miami Dolphins", "OAKWAS": "Washington Commanders",
}
Player_Season_and_Career_Stats['Team'] = Player_Season_and_Career_Stats['Team'].map(nfl_team_map)
NFL_Defense_Stats['Tm'] = NFL_Defense_Stats['Tm'].replace({'Washington Football Team':'Washington Commanders', 'Washington Redskins': 'Washington Commanders'})
QB_MVP_Votes['Tm'] = QB_MVP_Votes['Tm'].replace({'Washington Football Team':'Washington Commanders', 'Washington Redskins': 'Washington Commanders'})
Season_Standings['Tm'] = Season_Standings['Tm'].replace({'Washington Football Team':'Washington Commanders', 'Washington Redskins': 'Washington Commanders'})

# G: Games played by this team
# Cmp: Average Percentage of passes completed by opponent offense against this team
# Yds: Yards gained by passing by opponent offense against this team
# TD: Passing touchdowns scored against this team
# Int: Number of interceptions thrown against this team (An interception occurs when the ball is caught by a defensive player, turning possession of the ball to the other team)
# Y/A: Average Yards gained per pass attempt by opponent
NFL_Defense_Stats = NFL_Defense_Stats[['Tm', 'Year', 'G', 'Cmp', 'Yds', 'TD', 'Int', 'Y/A']] # only gather relevant columns for the research question

# Player: Quarterback name
# Season: Year of the season 
# Age: Age of quarterback
# Team: Team name the quarterback played for
# G: Games played
Player_Season_and_Career_Stats = Player_Season_and_Career_Stats[['Player', 'Season', 'Age', 'Team', 'G']]

# Year: The NFL regular season year in which MVP voting occurred
# Player: Name of the player receiving MVP votes
# Pos: Player position (filtered to quarterbacks for this project)
# Tm: Team the player represented during that season
# 1st Place Votes: Number of first-place MVP votes received
# Share: Percentage of total possible MVP voting points earned by the player (value between 0 and 1). A value closer to 1 indicates stronger voter consensus, while values near 0 indicate minimal support. This variable will serve as the dependent variable in our analysis.
QB_MVP_Votes = QB_MVP_Votes[['year', 'Player', 'Pos', 'Tm', '1st_Place_Votes', 'Share', 'Rk']]
QB_MVP_Votes = QB_MVP_Votes.fillna(0.0)

# Tm: Team name for that season
# W: Number of games won during the regular season
# L: Number of games lost during the regular season
# T: Number of games tied (added beginning in 2002)
# W-L%: Winning percentage (wins divided by total games played)
# PF: Total points scored by the team during the regular season
# PA: Total points allowed by the team during the regular season
# PD: Point differential (points scored minus points allowed)
# MoV: Margin of Victory, the average point differential per game
# SoS: Strength of Schedule, measuring the average quality of opponents based on SRS values
# SRS: Simple Rating System, a composite metric estimating overall team strength in points above or below league average
# OSRS: Offensive Simple Rating System, estimating offensive contribution to team strength
# DSRS: Defensive Simple Rating System, estimating defensive contribution to team strength
Season_Standings = Season_Standings[['Tm', 'Year', 'W', 'L', 'T', 'W-L%', 'PF', 'PA', 'PD', 'MoV', 'SoS', 'SRS', 'OSRS', 'DSRS']]

# The length of merged_df should be equal to length of Player_Season_and_Career_Stats which means every quarterback for every year was assigned data
merged_df = Player_Season_and_Career_Stats.merge(NFL_Defense_Stats, left_on=['Team', 'Season'], right_on=['Tm', 'Year'], how='left')
merged_df = merged_df.merge(QB_MVP_Votes, left_on=['Tm', 'Year', 'Player'], right_on=['Tm', 'year', 'Player'], how='left')
merged_df = merged_df.merge(Season_Standings, left_on=['Tm', 'Year'], right_on=['Tm', 'Year'], how='left')
merged_df.drop(['year', 'Pos'], axis=1, inplace=True)
# merged_df['1st_Place_Votes'] = merged_df['1st_Place_Votes'].fillna(-1)

print('All quarterbacks assigned their team data? ', len(merged_df) == len(Player_Season_and_Career_Stats))
